{
  "extends": "@tsconfig/recommended/tsconfig.json",
	"compilerOptions": {
		"declaration": true,
    "declarationMap": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "sourceMap": true
	},
	"include": ["client/**/*.ts", "index.ts"],
	"exclude": ["node_modules"]
}
